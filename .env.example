# Copy to .env for local development (never commit the real .env).

# Flask session signing key. Generate a strong random value in production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-only-change-me

# Absolute path to the SQLite database file.
# Locally this defaults to ./instance/portal.db if unset.
# On Railway, point this at the mounted volume, e.g. /data/portal.db
RAILWAY_DATABASE_PATH=

# Seed credentials for the first admin user, created on first boot if no users exist.
# Change the password immediately after first login.
SEED_ADMIN_NAME=Andrew
SEED_ADMIN_EMAIL=andrew@windbrook.example
SEED_ADMIN_PASSWORD=change-me-now
